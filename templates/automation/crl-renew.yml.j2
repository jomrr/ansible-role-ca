---
- name: Renew {{ ca_name }} CA CRLs
  hosts: localhost
  connection: local
  become: true
  gather_facts: false

  tasks:
{% for ca_authority_name in ca_authority_order %}
{% set ca_authority = ca_authorities[ca_authority_name] %}
{% for ca_crl_format in ca_crl.formats | default(['pem', 'der']) | map('lower') | list %}
    - name: "CA | Renew {{ ca_authority_name }} {{ ca_crl_format }} CRL"
      ca_crl:
        path: "{{ (ca_crl_format == 'der') | ternary(ca_base_dir ~ '/crl/' ~ ca_authority_name ~ '-ca.crl', ca_base_dir ~ '/crl/' ~ ca_authority_name ~ '-ca.crl.pem') }}"
        format: "{{ ca_crl_format }}"
        privatekey_path: "{{ ca_base_dir }}/private/{{ ca_authority_name }}-ca.key"
        privatekey_passphrase: "{{ "{{" }} lookup('ansible.builtin.file', '{{ ca_base_dir }}/private/{{ ca_authority_name }}-ca.pass') {{ "}}" }}"
        issuer_ordered:
          - countryName: {{ ca_country | to_json }}
          - stateOrProvinceName: {{ ca_state | to_json }}
          - localityName: {{ ca_locality | to_json }}
          - organizationName: {{ ca_organization | to_json }}
          - organizationalUnitName: {{ ca_organizational_unit | to_json }}
          - commonName: {{ ca_authority.common_name | to_json }}
        next_update_days: "{{ ca_authority.crl_days }}"
        revoked_certificates: {{ ca_revocations[ca_authority_name] | default([]) | to_json }}
        digest: "{{ ca_authority.digest | default(ca_default_md) }}"
        owner: "{{ ca_owner }}"
        group: "{{ ca_group }}"
        mode: "0644"
{% endfor %}
{% endfor %}
